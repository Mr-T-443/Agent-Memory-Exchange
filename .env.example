# Optional: override the default DB location (~/.amx/amx.db)
# AMX_DB_PATH=C:\path\to\amx.db

# Optional: Foundry IQ grounded search (memory_search federates when set)
# AMX_FOUNDRY_IQ_ENDPOINT=https://your-service.search.windows.net
# AMX_FOUNDRY_IQ_API_KEY=your-key
# AMX_FOUNDRY_IQ_INDEX=your-index
